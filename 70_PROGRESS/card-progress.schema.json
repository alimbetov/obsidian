{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alimbetov/obsidian/70_PROGRESS/card-progress.schema.json",
  "title": "Obsidian Knowledge System Per-Card Progress",
  "type": "object",
  "required": ["schema_version", "learner_id", "updated_at", "cards"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "learner_id": {"type": "string", "minLength": 1},
    "updated_at": {"type": ["string", "null"], "format": "date-time"},
    "cards": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+)*-B[0-9]+-C[0-9]+$"
      },
      "additionalProperties": {"$ref": "#/$defs/cardProgress"}
    }
  },
  "$defs": {
    "historyEvent": {
      "type": "object",
      "required": ["answered_at", "outcome", "confidence", "elapsed_seconds", "interval_before", "interval_after"],
      "additionalProperties": false,
      "properties": {
        "answered_at": {"type": "string", "format": "date-time"},
        "outcome": {
          "enum": [
            "correct-confident",
            "correct-guessed",
            "wrong-attention",
            "wrong-confusion",
            "wrong-concept"
          ]
        },
        "confidence": {"type": "integer", "minimum": 0, "maximum": 5},
        "elapsed_seconds": {"type": ["integer", "null"], "minimum": 0},
        "interval_before": {"type": "integer", "minimum": 0},
        "interval_after": {"type": "integer", "minimum": 0},
        "note": {"type": ["string", "null"]}
      }
    },
    "cardProgress": {
      "type": "object",
      "required": [
        "state",
        "attempts",
        "correct_attempts",
        "repetitions",
        "lapses",
        "ease_factor",
        "interval_days",
        "confidence",
        "last_outcome",
        "last_answered",
        "next_review",
        "suspended",
        "history"
      ],
      "additionalProperties": false,
      "properties": {
        "state": {"enum": ["new", "learning", "review", "relearning", "suspended"]},
        "attempts": {"type": "integer", "minimum": 0},
        "correct_attempts": {"type": "integer", "minimum": 0},
        "repetitions": {"type": "integer", "minimum": 0},
        "lapses": {"type": "integer", "minimum": 0},
        "ease_factor": {"type": "number", "minimum": 1.3, "maximum": 3.5},
        "interval_days": {"type": "integer", "minimum": 0},
        "confidence": {"type": "integer", "minimum": 0, "maximum": 5},
        "last_outcome": {
          "type": ["string", "null"],
          "enum": [
            null,
            "correct-confident",
            "correct-guessed",
            "wrong-attention",
            "wrong-confusion",
            "wrong-concept"
          ]
        },
        "last_answered": {"type": ["string", "null"], "format": "date"},
        "next_review": {"type": ["string", "null"], "format": "date"},
        "suspended": {"type": "boolean"},
        "history": {
          "type": "array",
          "items": {"$ref": "#/$defs/historyEvent"}
        }
      }
    }
  }
}
